# --- Secrets ---
TELEGRAM_BOT_TOKEN=
GOOGLE_API_KEY=

# --- Paths (defaults are fine for local dev, override for deployment) ---
# DATABASE_PATH=/path/to/aarogyam.db

# --- LLM / embeddings ---
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIM=768

# Force offline/deterministic mode (no network, no API key needed).
# Auto-enabled when GOOGLE_API_KEY is empty, but you can force it explicitly:
# AAROGYAM_OFFLINE_MODE=true

# --- Tiered memory tunables ---
MEMORY_WORKING_WINDOW=20
MEMORY_SUMMARIZE_AFTER=12
MEMORY_CONSOLIDATION_LOOKBACK_DAYS=14
MEMORY_DEDUP_SIMILARITY_THRESHOLD=0.90
MEMORY_RETRIEVAL_TOP_K=5

# --- RAG ---
RAG_TOP_K=3
